{
  "name": "bethesda-plugin-editor",
  "displayName": "mEdit",
  "description": "View, edit, and compare Bethesda plugin files (.esp/.esm/.esl)",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "mEdit.openEditor",
        "title": "mEdit: Open Editor"
      },
      {
        "command": "mEdit.openCompare",
        "title": "mEdit: Open Compare"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "tsc -p tsconfig.json && npm run build:webview",
    "build:webview": "vite build --config webview/vite.config.ts",
    "watch": "tsc -watch -p tsconfig.json",
    "pretest": "npm run build",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@types/vscode": "^1.85.0",
    "@vitejs/plugin-react": "^4.0.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0"
  },
  "dependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  }
}
