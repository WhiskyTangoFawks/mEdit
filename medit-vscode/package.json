{
  "name": "medit-vscode",
  "displayName": "mEdit",
  "description": "View, edit, and compare Bethesda plugin files (.esp/.esm/.esl)",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "mEdit",
      "properties": {
        "mEdit.backendPort": {
          "type": "number",
          "default": 5172,
          "description": "Port the mEdit backend API listens on."
        },
        "mEdit.game.dataFolderPath": {
          "type": "string",
          "default": "",
          "description": "Override: absolute path to the Fallout 4 Data folder. Leave blank for auto-detect."
        },
        "mEdit.game.pluginsTxtPath": {
          "type": "string",
          "default": "",
          "description": "Override: absolute path to Plugins.txt. Leave blank for auto-detect."
        },
        "mEdit.scriptsPath": {
          "type": "string",
          "default": "",
          "description": "Path to folder containing .sql filter files and .py scripts. Defaults to ~/.medit/scripts."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "medit",
          "title": "mEdit",
          "icon": "images/medit.svg"
        }
      ]
    },
    "views": {
      "medit": [
        {
          "id": "mEdit.modList",
          "name": "Mods",
          "when": "medit.viewMode == 'loadout'"
        },
        {
          "id": "mEdit.pluginTree",
          "name": "Plugins",
          "when": "medit.viewMode == 'editing'"
        },
        {
          "id": "mEdit.changeGroupTree",
          "name": "Change Groups",
          "when": "medit.viewMode == 'editing'"
        }
      ]
    },
    "commands": [
      {
        "command": "mEdit.openEditor",
        "title": "mEdit: Open Editor"
      },
      {
        "command": "mEdit.openCompare",
        "title": "mEdit: Open Compare"
      },
      {
        "command": "mEdit.loadSession",
        "title": "mEdit: Load Session"
      },
      {
        "command": "mEdit.reloadSession",
        "title": "mEdit: Reload Session"
      },
      {
        "command": "mEdit.refreshTree",
        "title": "mEdit: Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "mEdit.newPlugin",
        "title": "mEdit: New Plugin…",
        "icon": "$(add)"
      },
      {
        "command": "mEdit.copyAsOverrideInto",
        "title": "mEdit: Copy as Override Into…"
      },
      {
        "command": "mEdit.setFilter",
        "title": "mEdit: Filter Records…",
        "icon": "$(filter)"
      },
      {
        "command": "mEdit.clearFilter",
        "title": "mEdit: Clear Filter",
        "icon": "$(filter-filled)"
      },
      {
        "command": "mEdit.setFilterFromDocument",
        "title": "mEdit: Apply SQL File as Filter"
      },
      {
        "command": "mEdit.showReferencedBy",
        "title": "mEdit: Show Referenced By"
      },
      {
        "command": "mEdit.deleteRecord",
        "title": "mEdit: Delete Record"
      },
      {
        "command": "mEdit.createPlaced",
        "title": "mEdit: Create Placed…"
      },
      {
        "command": "mEdit.saveGroup",
        "title": "mEdit: Save Group",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "mEdit.revertGroup",
        "title": "mEdit: Revert Group",
        "icon": "$(discard)"
      },
      {
        "command": "mEdit.saveAllGroups",
        "title": "mEdit: Save All Groups",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "mEdit.revertAllGroups",
        "title": "mEdit: Revert All Groups",
        "icon": "$(discard)"
      },
      {
        "command": "mEdit.modList.filter",
        "title": "mEdit: Filter Mods…",
        "icon": "$(search)"
      },
      {
        "command": "mEdit.modList.switchProfile",
        "title": "mEdit: Switch Profile…",
        "icon": "$(account)"
      },
      {
        "command": "mEdit.modList.launchMedit",
        "title": "mEdit: Launch mEdit",
        "icon": "$(rocket)"
      },
      {
        "command": "mEdit.modList.refresh",
        "title": "mEdit: Refresh Mod List",
        "icon": "$(refresh)"
      },
      {
        "command": "mEdit.modList.mod.openInExplorer",
        "title": "Open in Explorer"
      },
      {
        "command": "mEdit.modList.mod.addSeparatorBelow",
        "title": "Add Separator Below…"
      },
      {
        "command": "mEdit.modList.mod.moveToSeparator",
        "title": "Move to Separator…"
      },
      {
        "command": "mEdit.modList.mod.uninstall",
        "title": "Uninstall…"
      },
      {
        "command": "mEdit.modList.mod.viewOnNexus",
        "title": "View on Nexus Mods"
      },
      {
        "command": "mEdit.modList.separator.rename",
        "title": "Rename…"
      },
      {
        "command": "mEdit.modList.separator.addSeparatorBelow",
        "title": "Add Separator Below…"
      },
      {
        "command": "mEdit.modList.separator.delete",
        "title": "Delete Separator"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "mEdit.refreshTree",
          "when": "view == mEdit.pluginTree",
          "group": "navigation"
        },
        {
          "command": "mEdit.newPlugin",
          "when": "view == mEdit.pluginTree",
          "group": "navigation"
        },
        {
          "command": "mEdit.setFilter",
          "when": "view == mEdit.pluginTree",
          "group": "navigation"
        },
        {
          "command": "mEdit.clearFilter",
          "when": "view == mEdit.pluginTree && mEdit.filterActive",
          "group": "navigation"
        },
        {
          "command": "mEdit.modList.filter",
          "when": "view == mEdit.modList",
          "group": "navigation@1"
        },
        {
          "command": "mEdit.modList.switchProfile",
          "when": "view == mEdit.modList",
          "group": "navigation@2"
        },
        {
          "command": "mEdit.modList.launchMedit",
          "when": "view == mEdit.modList",
          "group": "navigation@3"
        },
        {
          "command": "mEdit.modList.refresh",
          "when": "view == mEdit.modList",
          "group": "navigation@4"
        },
        {
          "command": "mEdit.saveAllGroups",
          "when": "view == mEdit.changeGroupTree",
          "group": "navigation"
        },
        {
          "command": "mEdit.revertAllGroups",
          "when": "view == mEdit.changeGroupTree",
          "group": "navigation"
        }
      ],
      "editor/title": [
        {
          "command": "mEdit.clearFilter",
          "when": "mEdit.filterActive",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "mEdit.copyAsOverrideInto",
          "when": "view == mEdit.pluginTree && viewItem == record",
          "group": "mEdit@1"
        },
        {
          "command": "mEdit.showReferencedBy",
          "when": "view == mEdit.pluginTree && viewItem == record",
          "group": "mEdit@2"
        },
        {
          "command": "mEdit.deleteRecord",
          "when": "view == mEdit.pluginTree && viewItem == record",
          "group": "mEdit@3"
        },
        {
          "command": "mEdit.createPlaced",
          "when": "view == mEdit.pluginTree && (viewItem == placedGroup-persistent || viewItem == placedGroup-temporary)",
          "group": "mEdit@1"
        },
        {
          "command": "mEdit.copyAsOverrideInto",
          "when": "view == mEdit.pluginTree && viewItem == refr",
          "group": "mEdit@1"
        },
        {
          "command": "mEdit.deleteRecord",
          "when": "view == mEdit.pluginTree && viewItem == refr",
          "group": "mEdit@2"
        },
        {
          "command": "mEdit.saveGroup",
          "when": "view == mEdit.changeGroupTree && viewItem == changeGroup",
          "group": "inline"
        },
        {
          "command": "mEdit.modList.mod.openInExplorer",
          "when": "view == mEdit.modList && viewItem == mod",
          "group": "modActions@1"
        },
        {
          "command": "mEdit.modList.mod.addSeparatorBelow",
          "when": "view == mEdit.modList && viewItem == mod",
          "group": "modActions@2"
        },
        {
          "command": "mEdit.modList.mod.moveToSeparator",
          "when": "view == mEdit.modList && viewItem == mod",
          "group": "modActions@3"
        },
        {
          "command": "mEdit.modList.mod.uninstall",
          "when": "view == mEdit.modList && viewItem == mod",
          "group": "modActions@4"
        },
        {
          "command": "mEdit.modList.mod.openInExplorer",
          "when": "view == mEdit.modList && viewItem == modWithNexus",
          "group": "modActions@1"
        },
        {
          "command": "mEdit.modList.mod.addSeparatorBelow",
          "when": "view == mEdit.modList && viewItem == modWithNexus",
          "group": "modActions@2"
        },
        {
          "command": "mEdit.modList.mod.moveToSeparator",
          "when": "view == mEdit.modList && viewItem == modWithNexus",
          "group": "modActions@3"
        },
        {
          "command": "mEdit.modList.mod.uninstall",
          "when": "view == mEdit.modList && viewItem == modWithNexus",
          "group": "modActions@4"
        },
        {
          "command": "mEdit.modList.mod.viewOnNexus",
          "when": "view == mEdit.modList && viewItem == modWithNexus",
          "group": "modActions@5"
        },
        {
          "command": "mEdit.modList.separator.rename",
          "when": "view == mEdit.modList && viewItem == separator",
          "group": "sepActions@1"
        },
        {
          "command": "mEdit.modList.separator.addSeparatorBelow",
          "when": "view == mEdit.modList && viewItem == separator",
          "group": "sepActions@2"
        },
        {
          "command": "mEdit.modList.separator.delete",
          "when": "view == mEdit.modList && viewItem == separator",
          "group": "sepActions@3"
        },
        {
          "command": "mEdit.revertGroup",
          "when": "view == mEdit.changeGroupTree && viewItem == changeGroup",
          "group": "inline"
        }
      ]
    },
    "keybindings": [
      {
        "command": "mEdit.deleteRecord",
        "key": "Delete",
        "when": "focusedView == mEdit.pluginTree && viewItem == record"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "tsc -p tsconfig.json --noEmit && node esbuild.mjs && npm run build:webview",
    "build:webview": "VITE_CJS_IGNORE_WARNING=1 vite build --config webview/vite.config.ts",
    "watch": "node esbuild.mjs --watch",
    "generate-api": "openapi-typescript http://localhost:5172/swagger/v1/swagger.json -o src/generated/api.ts",
    "test:unit": "vitest run",
    "test:integration": "tsc -p tsconfig.integration.json && vscode-test",
    "lint": "eslint src webview/src"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/mocha": "^10.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "@vitejs/plugin-react": "^4.0.0",
    "@vitest/coverage-v8": "^2.1.9",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "happy-dom": "^20.9.0",
    "jsdom": "^29.1.1",
    "openapi-typescript": "^7.13.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.60.1",
    "vite": "^5.0.0",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "openapi-fetch": "^0.17.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  }
}
